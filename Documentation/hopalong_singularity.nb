Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"b", "=", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"c", "=", "3"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nMax", "=", "100"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Number", " ", "of", " ", "iterations"}], "*)"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "compiled", " ", "function"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cf", "=", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "_Real"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "_Real"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"y", "-", 
         RowBox[{
          RowBox[{"Sign", "[", "x", "]"}], " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"b", " ", "x"}], "-", "c"}], "]"}], "]"}]}]}], ",", 
        RowBox[{"a", "-", "x"}]}], "}"}], ",", 
      RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
      RowBox[{"RuntimeOptions", "->", "\"\<Speed\>\""}]}], "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Initialize", " ", "x", " ", "and", " ", "y"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "0."}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "=", "0."}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Preallocate", " ", "lists"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xValues", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0.", ",", 
     RowBox[{"{", 
      RowBox[{"nMax", "+", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"yValues", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0.", ",", 
      RowBox[{"{", 
       RowBox[{"nMax", "+", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Initial", " ", "values"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xValues", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "x"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"yValues", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "=", "y"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Perform", " ", "the", " ", "iterations"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], "=", 
       RowBox[{"cf", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"xValues", "[", 
        RowBox[{"[", 
         RowBox[{"n", "+", "1"}], "]"}], "]"}], "=", "x"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"yValues", "[", 
        RowBox[{"[", 
         RowBox[{"n", "+", "1"}], "]"}], "]"}], "=", "y"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "nMax"}], "}"}]}], "]"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Output", " ", "results"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{"xValues", ",", "yValues"}], "}"}]}], "Input",
